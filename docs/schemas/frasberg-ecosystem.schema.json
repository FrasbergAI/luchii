{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frasbergai.com/schemas/frasberg-ecosystem.schema.json",
  "title": "Frasberg Ecosystem Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "collection",
    "version",
    "sourceFormat",
    "summary",
    "normalizationNotes",
    "entries"
  ],
  "properties": {
    "collection": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "sourceFormat": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "normalizationNotes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "category", "formalName", "summary", "sections"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "title": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "formalName": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["heading", "items"],
              "properties": {
                "heading": {"type": "string", "minLength": 1},
                "items": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name", "detail"],
                    "properties": {
                      "name": {"type": "string", "minLength": 1},
                      "detail": {"type": "string", "minLength": 1}
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}