{
  "name": "FrasbergAI-Hotfix-Protection",
  "description": "Emergency fix enforcement with accelerated review and direct merge paths to main and stable",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_type": "OrganizationAdmin",
      "actor_id": null
    },
    {
      "actor_type": "Team",
      "actor_id": "on-call"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/hotfix/*"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 1,
        "required_review_thread_resolution": false
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "ci/hotfix-pipeline"
          },
          {
            "context": "security/hotfix-scan"
          }
        ]
      }
    },
    {
      "type": "required_signatures",
      "parameters": {}
    },
    {
      "type": "non_fast_forward",
      "parameters": {}
    },
    {
      "type": "deletion",
      "parameters": {}
    },
    {
      "type": "update",
      "parameters": {
        "allowed_update_rules": [
          {
            "type": "pull_request"
          }
        ]
      }
    }
  ]
}
