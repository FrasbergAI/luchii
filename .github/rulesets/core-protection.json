{
  "name": "FrasbergAI-Core-Protection",
  "description": "Production-grade protection for main, stable, and release branches - Enterprise AI Model enforcement",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_type": "OrganizationAdmin",
      "actor_id": null
    }
  ],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/main",
        "refs/heads/stable",
        "refs/heads/release/*"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": true,
        "require_last_push_approval": true,
        "required_approving_review_count": 2,
        "required_review_thread_resolution": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "continuous-integration/github-actions"
          },
          {
            "context": "code-quality/errors"
          },
          {
            "context": "test-coverage/main"
          }
        ]
      }
    },
    {
      "type": "commit_message_pattern",
      "parameters": {
        "operator": "starts_with",
        "pattern": "Merge pull request"
      }
    },
    {
      "type": "commit_author_email_pattern",
      "parameters": {
        "operator": "contains",
        "pattern": ""
      }
    },
    {
      "type": "committer_email_pattern",
      "parameters": {
        "operator": "contains",
        "pattern": ""
      }
    },
    {
      "type": "creation",
      "parameters": {}
    },
    {
      "type": "update",
      "parameters": {
        "allowed_update_rules": [
          {
            "type": "pull_request"
          }
        ]
      }
    },
    {
      "type": "deletion",
      "parameters": {}
    },
    {
      "type": "non_fast_forward",
      "parameters": {}
    },
    {
      "type": "required_signatures",
      "parameters": {}
    }
  ]
}
