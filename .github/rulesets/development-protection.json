{
  "name": "FrasbergAI-Development-Protection",
  "description": "Balanced protection for active development and feature branches with developer flexibility",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_type": "Team",
      "actor_id": "team-leads"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/feature/*",
        "refs/heads/dev"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 1,
        "required_review_thread_resolution": false
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "required_status_checks": [
          {
            "context": "continuous-integration/build"
          },
          {
            "context": "linting/style"
          },
          {
            "context": "test/unit"
          }
        ]
      }
    },
    {
      "type": "non_fast_forward",
      "parameters": {}
    },
    {
      "type": "deletion",
      "parameters": {}
    },
    {
      "type": "update",
      "parameters": {
        "allowed_update_rules": [
          {
            "type": "pull_request"
          }
        ]
      }
    }
  ]
}
