{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frasberg.ai/schemas/luchii/routing.schema.v1.0.0.json",
  "title": "Luchii Router Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rules"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/routingRule"
      }
    }
  },
  "$defs": {
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["providerId", "model"],
      "properties": {
        "providerId": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number"
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "routingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "model"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "tenant": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "$ref": "#/$defs/modelConfig"
        }
      }
    }
  }
}
