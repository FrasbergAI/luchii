# Frasberg Autonomous Cloud Configuration

PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=autonomous_cloud

# JWT
JWT_SECRET=dev-secret-change-in-production

# Telemetry
TELEMETRY_ENABLED=true
LOG_LEVEL=info

# Multi-region configuration
REGIONS=us-west,us-east,eu-central,apac,latam,middle-east,africa
DEFAULT_REGION=us-west

# Commercial
ENABLE_BILLING=true
BILLING_CURRENCY=USD
