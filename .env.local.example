# Local Development Environment Configuration
# Copy this file to .env.local and update values for your environment

# ============================================================================
# Backend Configuration
# ============================================================================

# Environment
ENVIRONMENT=local
DEBUG=1

# Model Configuration
MODEL_NAME=LUCHII
FRASBERGAI_VERSION=v1

# Server Configuration
HOST=0.0.0.0
PORT=8080
API_PREFIX=/api

# Database Configuration (update for your local setup)
FRASBERGAI_DB_URL=postgresql://user:password@localhost:5432/luchii_dev

# API Keys & Tokens (use dummy values for local development)
FRASBERGAI_API_KEY=local-dev-key-change-in-production
FRASBERGAI_MODEL_TOKEN=local-dev-token-change-in-production
FRASBERGAI_DEPLOY_KEY=local-dev-deploy-key-change-in-production

# Region
REGION=us-west-2-local

# ============================================================================
# UI Configuration
# ============================================================================

# API Endpoint (backend must be running on this URL)
VITE_API_URL=http://localhost:8080

# Judge Dashboard (http://localhost:5173)
VITE_JUDGE_PORT=5173

# Lawyer Dashboard (http://localhost:5174)
VITE_LAWYER_PORT=5174

# Clerk Dashboard (http://localhost:5175)
VITE_CLERK_PORT=5175

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Log Format (simple or json)
LOG_FORMAT=simple

# ============================================================================
# Development Tools
# ============================================================================

# Enable CORS for local development
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Enable API documentation
ENABLE_DOCS=true

# ============================================================================
# Docker Configuration (if using docker-compose.local.yml)
# ============================================================================

# Database container environment
POSTGRES_USER=luchii_dev
POSTGRES_PASSWORD=local_dev_password_change_in_production
POSTGRES_DB=luchii_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis configuration (optional caching)
REDIS_URL=redis://redis:6379

# ============================================================================
# Feature Flags
# ============================================================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Enable analytics for local development
ENABLE_ANALYTICS=false

# Enable profiling
ENABLE_PROFILING=false
