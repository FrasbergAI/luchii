{
  "name": "FrasbergAI-All-Branches-Baseline",
  "description": "Universal baseline security rules applied to all branches in the repository",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_type": "OrganizationAdmin",
      "actor_id": null
    }
  ],
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/*"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_signatures",
      "parameters": {}
    },
    {
      "type": "non_fast_forward",
      "parameters": {}
    },
    {
      "type": "deletion",
      "parameters": {
        "patterns": [
          {
            "name": "*",
            "negate": false
          }
        ]
      }
    },
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_approving_review_count": 0,
        "required_review_thread_resolution": true
      }
    }
  ]
}
